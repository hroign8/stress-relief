# Copy to .env.local and fill in. Do not commit .env.local.

# Public site URL — used for SEO metadata (Open Graph / Twitter / canonical).
# Set this to the real production domain.
NEXT_PUBLIC_SITE_URL=https://stressreliefclean.com

# Resend email delivery for booking/quote requests.
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Where new booking/quote requests are emailed.
QUOTE_TO_EMAIL=stressrelieffamilycleaningserv@gmail.com

# The "from" sender. onboarding@resend.dev works immediately but in test mode
# only delivers to the email you used to sign up for Resend. Switch to an
# address on a verified domain to send to any recipient.
QUOTE_FROM_EMAIL=onboarding@resend.dev
